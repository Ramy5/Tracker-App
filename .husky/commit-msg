
#!/bin/sh

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

printf "${BLUE}===============================${NC}\n"
printf "${CYAN}📝 Checking Commit Message format...${NC}\n"
printf "${BLUE}===============================${NC}\n"

INPUT_FILE=$1
COMMIT_MSG=$(cat "$INPUT_FILE")

# Pattern: type(PROJECT-ID): subject
# Types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert
# Scope: Must be uppercase letter and numbers (e.g. GOLD-01)
PATTERN="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)\([A-Z]+-[0-9]+\): .+$"

if ! echo "$COMMIT_MSG" | grep -Eq "$PATTERN"; then
  printf "${RED}❌ Invalid Commit Message Format!${NC}\n"
  printf "${BLUE}===============================${NC}\n"
  printf "${YELLOW}The commit message must follow this strict pattern:${NC}\n"
  printf "${CYAN}<type>(<PROJECT-ID>): <subject>${NC}\n"
  printf "\n"
  printf "${YELLOW}Allowed Types:${NC}\n"
  printf "  - feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert\n"
  printf "\n"
  printf "${YELLOW}Examples:${NC}\n"
  printf "  - ${GREEN}feat(GOLD-123): add new user profile page${NC}\n"
  printf "  - ${GREEN}fix(AUTH-42): correct login validation error${NC}\n"
  printf "  - ${GREEN}chore(INFRA-9): update dependencies${NC}\n"
  printf "\n"
  printf "${RED}Your message was:${NC}\n"
  printf "$COMMIT_MSG\n"
  exit 1
fi

# Run commitlint for additional validation
printf "${CYAN}🔍 Running commitlint validation...${NC}\n"
npx --no-install commitlint --edit ${1}

if [ $? -ne 0 ]; then
  printf "${RED}❌ Commitlint validation failed!${NC}\n"
  printf "${BLUE}===============================${NC}\n"
  exit 1
fi

printf "${GREEN}✅ Commit message is valid.${NC}\n"
printf "${BLUE}===============================${NC}\n"
exit 0
