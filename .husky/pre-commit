#!/bin/sh

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

printf "${BLUE}===============================${NC}\n"
printf "${CYAN}⚙️  Starting Pre-Commit Checks...${NC}\n"
printf "${BLUE}===============================${NC}\n"

# ------------------------------------
# 1. Run Lint-Staged (Linting & Formatting)
# ------------------------------------
printf "${YELLOW}🔎 Running Lint-Staged for staged files...${NC}\n"
npx lint-staged
EXIT_CODE=$?
if [ $EXIT_CODE -ne 0 ]; then
  printf "${RED}❌📝 Linting and Formatting failed! Please fix all issues before committing.${NC}\n"
  exit $EXIT_CODE
fi
printf "${GREEN}✅📝 Linting and Formatting went well!${NC}\n"
printf "${BLUE}===============================${NC}\n"

# ------------------------------------
# 2. Run Build
# ------------------------------------
printf "${YELLOW}📝 Running Build...${NC}\n"
npm run build
EXIT_CODE=$?
if [ $EXIT_CODE -ne 0 ]; then
  printf "${RED}❌🏗️ Build failed! Please fix build/type errors before committing.${NC}\n"
  exit $EXIT_CODE
fi
printf "${GREEN}✅🏗️ Build passed!${NC}\n"
printf "${BLUE}===============================${NC}\n"

# ------------------------------------
# 5. Branch Naming Convention Check
# ------------------------------------
printf "${YELLOW}🔍 Checking branch naming convention...${NC}\n"

# Get the current branch name
branch_name=$(git symbolic-ref --short HEAD 2>/dev/null)

# Check if we are in a detached HEAD state or no branch
if [ -z "$branch_name" ]; then
  printf "${RED}❌ Could not determine branch name (Detached HEAD?)${NC}\n"
  exit 1
fi

# Allowed Pattern: main, dev, or xx-type-PROJECT-1234-description
# Types: fix, feat, chore, docs, refactor, style, test
if ! echo "$branch_name" | grep -Eq '^(main|dev|[a-z]{2}-(fix|feat|chore|docs|refactor|style|test)-[A-Z]{1,10}-[0-9]+-[a-z0-9-]+)$'; then
  printf "${BLUE}===============================${NC}\n"
  printf "${RED}❌ Invalid branch name: ${YELLOW}$branch_name${NC}\n"
  printf "${BLUE}===============================${NC}\n"
  printf "${RED}Branch Naming Convention Failed. Examples of VALID names:${NC}\n"
  printf "\n"
  printf "  - ${CYAN}Bypass Branches:${NC} ${GREEN}main, dev${NC}\n"
  printf "  - ${CYAN}New Feature:${NC}     ${GREEN}rs-feat-DASH-1234-add-user-profile-editing${NC}\n"
  printf "  - ${CYAN}Bug Fix:${NC}         ${GREEN}ah-fix-BUG-42-correct-rtl-sidebar-alignment${NC}\n"
  printf "  - ${CYAN}Maintenance:${NC}     ${GREEN}ah-chore-INFRA-9-update-npm-dependencies${NC}\n"
  printf "  - ${CYAN}Refactoring:${NC}     ${GREEN}ah-refactor-CORE-501-simplify-logic${NC}\n"
  printf "  - ${CYAN}Documentation:${NC}   ${GREEN}rs-docs-WIKI-101-update-api-usage-guide${NC}\n"
  printf "\n"
  printf "${YELLOW}Required Pattern:${NC} [developer_name]-[type]-[PROJECT_CODE]-[TICKET_ID]-[description]\n"
  exit 1
fi

printf "${GREEN}✅ Branch name is valid: ${branch_name}${NC}\n"
printf "${BLUE}===============================${NC}\n"

# If all checks pass, allow the commit
exit 0